import sys
import os
import threading
import subprocess
import tempfile
import time
import boto3
import customtkinter as ctk
from tkinter import filedialog, messagebox
import tomllib
from boto3.s3.transfer import TransferConfig
import botocore
if not hasattr(botocore, 'vendored'):
    botocore.vendored = type('fake', (), {'requests': None})


# 设置外观模式和主题
ctk.set_appearance_mode("System")
ctk.set_default_color_theme("blue")

class ProgressPercentage:
    """进度回调类"""
    def __init__(self, filename, total_size, progress_callback):
        self._filename = filename
        self._total_size = float(total_size)
        self._seen_so_far = 0
        self._callback = progress_callback
        self._lock = threading.Lock()

    def __call__(self, bytes_amount):
        with self._lock:
            self._seen_so_far += bytes_amount
            percentage = self._seen_so_far / self._total_size
            self._callback(percentage)

class S3UploaderApp(ctk.CTk):
    def __init__(self):
        super().__init__()
        self.version = self.get_version()
        self.title(f"AWS S3 上传助手 v{self.version}")
        self.geometry("550x650")
        self.resizable(False, False)
        
        self.selected_files = []
        self.is_uploading = False
        
        # 创建临时目录
        self.temp_dir = tempfile.mkdtemp(prefix="s3_uploader_")
        
        # 确保程序退出时清理临时文件
        self.protocol("WM_DELETE_WINDOW", self.on_closing)

        # 1. 标题
        self.label = ctk.CTkLabel(self, text="AWS S3 配置", font=("Arial", 16, "bold"))
        self.label.pack(pady=(20, 10))

        # 2. 凭证输入框
        self.key_entry = ctk.CTkEntry(self, width=350, placeholder_text="Access Key ID", show="*")
        self.key_entry.pack(pady=5)

        self.secret_entry = ctk.CTkEntry(self, width=350, placeholder_text="Secret Access Key", show="*")
        self.secret_entry.pack(pady=5)

        self.bucket_entry = ctk.CTkEntry(self, width=350, placeholder_text="Bucket 名称")
        self.bucket_entry.pack(pady=5)

        # 3. 状态标签
        self.status_label = ctk.CTkLabel(self, text="就绪", font=("Arial", 12), text_color="gray")
        self.status_label.pack(pady=10)

        # 4. 进度条 (初始隐藏，设置为0)
        self.progress_bar = ctk.CTkProgressBar(self, width=350)
        self.progress_bar.set(0)  # 明确设置为0
        # 初始不显示进度条，只有开始上传时才显示
        # self.progress_bar.pack(pady=10)  # 注释掉，不自动显示

        # 5. 按钮
        self.btn_select = ctk.CTkButton(self, text="选择文件或文件夹", command=self.select_files, 
                                        fg_color="#FF9800", hover_color="#F57C00", width=200)
        self.btn_select.pack(pady=10)

        self.btn_upload = ctk.CTkButton(self, text="开始上传", command=self.upload_to_s3, 
                                        fg_color="#E65100", hover_color="#BF360C", 
                                        state="disabled", width=200)
        self.btn_upload.pack(pady=10)

        # 6. 底部信息
        footer_text = f"Designed by Maxwell @2026 | v{self.version}"
        self.footer = ctk.CTkLabel(self, text=footer_text, font=("Arial", 12), text_color="gray")
        self.footer.pack(side="bottom", pady=20)

    def get_version(self):
        try:
            base_path = getattr(sys, '_MEIPASS', os.path.dirname(os.path.abspath(__file__)))
            toml_path = os.path.join(base_path, 'pyproject.toml')
            with open(toml_path, "rb") as f:
                data = tomllib.load(f)
                return data["project"].get("version", "1.0.0")
        except Exception:
            return "1.0.0"

    def on_closing(self):
        """清理临时文件后退出"""
        try:
            import shutil
            if os.path.exists(self.temp_dir):
                shutil.rmtree(self.temp_dir)
        except:
            pass
        self.destroy()

    def select_files(self):
        # 允许用户选择多个文件或文件夹
        filenames = filedialog.askopenfilenames(title="选择文件或文件夹")
        if filenames:
            self.selected_files = list(filenames)
            self.btn_select.configure(text=f"已选 {len(filenames)} 个项目")
            self.btn_upload.configure(state="normal")
            # 选择文件后重置进度条（但保持隐藏）
            self.progress_bar.set(0)
            self.update_status(f"已选择 {len(filenames)} 个项目")

    def reset_ui(self):
        """重置界面（上传完成后调用）"""
        self.is_uploading = False
        self.selected_files = []
        self.btn_select.configure(text="选择文件或文件夹")
        self.btn_upload.configure(state="normal", text="开始上传")
        # 重置进度条并隐藏
        self.progress_bar.set(0)
        self.progress_bar.pack_forget()  # 隐藏进度条
        self.update_status("就绪")

    def update_status(self, message):
        """更新状态栏"""
        self.after(0, lambda: self.status_label.configure(text=message))

    def update_progress(self, percentage, overall_progress=None):
        """更新进度条"""
        if overall_progress is not None:
            self.after(0, lambda: self.progress_bar.set(overall_progress))
        else:
            self.after(0, lambda: self.progress_bar.set(percentage))

    def compress_with_progress(self, source_path, output_path):
        """带进度反馈的压缩函数"""
        self.update_status(f"正在压缩: {os.path.basename(source_path)}...")
        
        # 使用 zip 命令
        process = subprocess.Popen(
            ['zip', '-r', output_path, source_path],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True
        )
        
        # 等待完成
        stdout, stderr = process.communicate()
        
        if process.returncode != 0:
            raise Exception(f"压缩失败: {stderr}")
        
        self.update_status("压缩完成")
        return output_path

    def upload_with_progress(self, s3_client, file_path, bucket, key):
        """带进度反馈的上传"""
        file_size = os.path.getsize(file_path)
        progress = ProgressPercentage(key, file_size, self.update_progress)
        
        # 配置传输选项（优化大文件上传）
        config = TransferConfig(
            multipart_threshold=10 * 1024 * 1024,  # 10MB 以上使用分块上传
            max_concurrency=5,  # 并发上传分块数
            multipart_chunksize=5 * 1024 * 1024,  # 每块 5MB
            use_threads=True
        )
        
        s3_client.upload_file(
            Filename=file_path,
            Bucket=bucket,
            Key=key,
            Callback=progress,
            Config=config
        )

    def _perform_upload(self, aws_key, aws_secret, bucket_name):
        """执行实际上传任务"""
        self.is_uploading = True
        s3_client = None
        
        try:
            # 创建 S3 客户端
            s3_client = boto3.client(
                's3', 
                aws_access_key_id=aws_key, 
                aws_secret_access_key=aws_secret
            )
            
            total_items = len(self.selected_files)
            processed = 0
            
            for idx, path in enumerate(self.selected_files):
                if not self.is_uploading:
                    break
                
                is_temp = False
                upload_path = path
                s3_key = os.path.basename(path)
                
                # 检查是否需要压缩
                if os.path.isdir(path) or (os.path.isfile(path) and path.endswith('.app')):
                    self.update_status(f"正在压缩: {s3_key}...")
                    # 在临时目录创建 zip 文件
                    zip_name = s3_key + ".zip"
                    upload_path = os.path.join(self.temp_dir, zip_name)
                    s3_key = zip_name  # 上传到 S3 时使用 .zip 名称
                    
                    # 执行压缩
                    self.compress_with_progress(path, upload_path)
                    is_temp = True
                
                # 上传文件
                self.update_status(f"正在上传: {s3_key} ({idx+1}/{total_items})...")
                self.upload_with_progress(s3_client, upload_path, bucket_name, s3_key)
                
                # 清理临时文件
                if is_temp and os.path.exists(upload_path):
                    os.remove(upload_path)
                
                # 更新整体进度
                processed += 1
                overall_progress = processed / total_items
                self.update_progress(overall_progress, overall_progress)
            
            if self.is_uploading:
                self.update_status("上传完成！")
                self.after(0, lambda: messagebox.showinfo("成功", f"全部 {total_items} 个项目上传成功！"))
                self.after(0, self.reset_ui)
            else:
                self.update_status("上传已取消")
                
        except Exception as e:
            error_msg = str(e)
            print(f"上传错误详情: {error_msg}")
            self.update_status(f"错误: {error_msg[:50]}...")
            self.after(0, lambda: messagebox.showerror("错误", f"上传失败: {error_msg}"))
            self.after(0, lambda: self.btn_upload.configure(state="normal", text="开始上传"))
            self.after(0, lambda: self.progress_bar.pack_forget())
        finally:
            self.is_uploading = False

    def upload_to_s3(self):
        if self.is_uploading:
            # 如果正在上传，允许取消
            self.is_uploading = False
            self.btn_upload.configure(state="disabled", text="正在取消...")
            self.update_status("正在取消上传...")
            return
            
        aws_key = self.key_entry.get().strip()
        aws_secret = self.secret_entry.get().strip()
        bucket_name = self.bucket_entry.get().strip()

        if not all([aws_key, aws_secret, bucket_name]):
            messagebox.showwarning("警告", "请填写完整的凭证和 Bucket 名称")
            return
        
        if not self.selected_files:
            messagebox.showwarning("警告", "请先选择要上传的文件或文件夹")
            return

        # 显示进度条并重置为0
        self.progress_bar.pack(pady=10)
        self.progress_bar.set(0)  # 确保进度条从0开始
        self.btn_upload.configure(state="disabled", text="上传中... (点击取消)")
        self.update_status("准备上传...")
        
        upload_thread = threading.Thread(target=self._perform_upload, args=(aws_key, aws_secret, bucket_name))
        upload_thread.daemon = True
        upload_thread.start()

if __name__ == "__main__":
    app = S3UploaderApp()
    app.mainloop()